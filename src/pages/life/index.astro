---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const categoryOrder = ['清洁', '体态矫正', '急救及健康', '用电常识', '厨房指南'];
const entries = (await getCollection('life')).sort((a, b) => a.data.order - b.data.order);
const groups = categoryOrder
  .map((category) => ({ category, entries: entries.filter((entry) => entry.data.category === category) }))
  .filter((group) => group.entries.length);
const base = import.meta.env.BASE_URL;
---

<Layout title="生活" currentBoard="life">
  <section class="domain-page">
    <div class="domain-hero">
      <span class="hero-eyebrow">LIFE</span>
      <h1>生活</h1>
      <p>过日子用得上的生活常识</p>
    </div>

    <div class="domain-toolbar">
      <span>生活领域地图</span>
      <span>{entries.length} 条记录</span>
    </div>

    {groups.map((group) => (
      <section class="record-group" aria-labelledby={`category-${group.category}`}>
        <h2 id={`category-${group.category}`}>{group.category}</h2>
        <div class="record-grid">
          {group.entries.map((entry) => (
            <a class="record-card" href={`${base}life/${entry.slug}/`}>
              <span class="record-date">{entry.data.date ? entry.data.date.toLocaleDateString('zh-CN') : '未标注日期'}</span>
              <strong>{entry.data.title}</strong>
              {entry.data.source && <span class="record-source">来源：{entry.data.source}</span>}
              <span class="record-arrow">查看详情 →</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </section>
</Layout>
