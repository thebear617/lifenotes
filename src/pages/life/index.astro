---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { topicIdForLabel } from '../../data/topics.js';

const categoryOrder = ['清洁', '体态矫正', '急救及健康', '用电常识', '厨房指南'];
const entries = (await getCollection('life'))
  .filter((entry) => entry.data.visible)
  .sort((a, b) => a.data.order - b.data.order);
const records = categoryOrder
  .map((category) => ({ category, entries: entries.filter((entry) => entry.data.category === category) }))
  .filter((group) => group.entries.length)
  .flatMap((group) => group.entries.map((entry) => ({ entry, category: group.category })))
  .sort((a, b) => {
    const dateA = a.entry.data.date?.getTime() ?? Number.POSITIVE_INFINITY;
    const dateB = b.entry.data.date?.getTime() ?? Number.POSITIVE_INFINITY;
    return dateB - dateA;
  });
const base = import.meta.env.BASE_URL;
---

<Layout title="生活" currentBoard="life" topicFilter={true}>
  <section class="domain-page">
    <div class="life-record-list">
      {records.map(({ entry, category }) => (
        <a class="record-card" data-topic-section={topicIdForLabel('life', category)} href={`${base}life/${entry.slug}/`}>
          <div class="record-card-topline">
            <span class="record-category">{category}</span>
            <span class="record-date">{entry.data.date ? entry.data.date.toLocaleDateString('zh-CN') : '未标注日期'}</span>
          </div>
          <strong>{entry.data.title}</strong>
          {entry.data.format === 'article' && <span class="record-summary">专题文章 · 汇总多条生活知识</span>}
          {entry.data.source && <span class="record-source">来源：{entry.data.source}</span>}
          <span class="record-arrow">查看详情 →</span>
        </a>
      ))}
    </div>
  </section>
</Layout>

<script>
  let filterTimer;

  document.addEventListener('click', (event) => {
    const button = event.target.closest('[data-topic-filter]');
    if (!button) return;

    const selected = button.dataset.topicFilter || 'all';
    const list = document.querySelector('.life-record-list');
    if (!list) return;

    document.querySelectorAll('[data-topic-filter]').forEach((item) => {
      const isActive = item === button;
      item.classList.toggle('active', isActive);
      item.setAttribute('aria-pressed', String(isActive));
    });

    clearTimeout(filterTimer);
    list.classList.add('is-switching');
    filterTimer = setTimeout(() => {
      document.querySelectorAll('[data-topic-section]').forEach((record) => {
        record.classList.toggle('is-filtered-out', selected !== 'all' && record.dataset.topicSection !== selected);
      });
      requestAnimationFrame(() => list.classList.remove('is-switching'));
    }, 160);
  });
</script>
