---
import Layout from '../../layouts/Layout.astro';
import boards from '../../data/boards.js';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const getFormalEntries = (id) => {
    switch (id) {
      case 'ai': return getCollection('ai');
      case 'auto': return getCollection('auto');
      case 'biology': return getCollection('biology');
      case 'finance': return getCollection('finance');
      case 'food': return getCollection('food');
      case 'pet': return getCollection('pet');
      default: return [];
    }
  };
  return Promise.all(boards
    .filter((board) => !['life', 'hotel', 'phone'].includes(board.id))
    .map(async (board) => ({
      params: { board: board.id },
      props: { board, entries: await getFormalEntries(board.id) },
    })));
}

const { board, entries } = Astro.props;
const base = import.meta.env.BASE_URL;
const categories = [...new Set(entries.map((entry) => entry.data.category || '未分类'))];
---

<Layout title={board.name} currentBoard={board.id}>
  <section class="board-placeholder">
    <span class="board-placeholder-icon">{board.icon}</span>
    <p class="hero-eyebrow">{board.name}</p>
    <h1>{board.name}</h1>
    <p>{board.desc}</p>
    {entries.length ? (
      <>
        <div class="domain-toolbar">
          <span>{board.name}领域地图</span>
          <span>{entries.length} 条记录</span>
        </div>
        {categories.map((category) => (
          <section class="record-group" aria-labelledby={`category-${category}`}>
            <h2 id={`category-${category}`}>{category}</h2>
            <div class="record-grid">
              {entries.filter((entry) => entry.data.category === category).sort((a, b) => a.data.order - b.data.order).map((entry) => (
                <a class="record-card" href={`${base}${board.id}/${entry.slug}/`}>
                  <span class="record-date">{entry.data.date ? entry.data.date.toLocaleDateString('zh-CN') : '未标注日期'}</span>
                  <strong>{entry.data.title}</strong>
                  {entry.data.source && <span class="record-source">来源：{entry.data.source}</span>}
                  <span class="record-arrow">查看详情 →</span>
                </a>
              ))}
            </div>
          </section>
        ))}
      </>
    ) : (
      <div class="placeholder-box">
        <strong>暂无可发布记录</strong>
        <span>该领域已接入 Astro 导航，后续有正式记录后会自动生成详情页。</span>
      </div>
    )}
    <a class="back-link" href={base}>← 返回领域总览</a>
  </section>
</Layout>
