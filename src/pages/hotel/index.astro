---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { categoryForEntry, compareEntriesByDateDesc } from '../../data/content.js';

const entries = (await getCollection('hotel')).filter((entry) => entry.data.visible).sort(compareEntriesByDateDesc);
const topics = [...new Set(entries.map(categoryForEntry))].map((label) => ({ id: label, label }));
const base = import.meta.env.BASE_URL;
---

<Layout title="酒店" currentBoard="hotel" topicFilter={true} topicItems={topics}>
  <section class="domain-page">
    <div class="life-record-list">
      {entries.map((entry) => {
        const category = categoryForEntry(entry);
        return (
        <a class="record-card" data-topic-section={category} href={`${base}hotel/${entry.slug}/`}>
          <div class="record-card-topline"><span class="record-category">{category}</span><span class="record-date">{entry.data.date ? entry.data.date.toLocaleDateString('zh-CN') : '未标注日期'}</span></div>
          <strong>{entry.data.title}</strong>
          {entry.data.description && <span class="record-description">{entry.data.description}</span>}
          <span class="record-source">来源：{entry.data.source}</span>
          <span class="record-arrow">查看详情 →</span>
        </a>
        );
      })}
    </div>
  </section>
</Layout>

<script>
  let filterTimer;
  document.addEventListener('click', (event) => {
    const button = event.target.closest('[data-topic-filter]');
    if (!button) return;
    const list = document.querySelector('.life-record-list');
    if (!list) return;
    const selected = button.dataset.topicFilter || 'all';
    document.querySelectorAll('[data-topic-filter]').forEach((item) => {
      const active = item === button;
      item.classList.toggle('active', active);
      item.setAttribute('aria-pressed', String(active));
    });
    clearTimeout(filterTimer);
    list.classList.add('is-switching');
    filterTimer = setTimeout(() => {
      document.querySelectorAll('[data-topic-section]').forEach((record) => record.classList.toggle('is-filtered-out', selected !== 'all' && record.dataset.topicSection !== selected));
      requestAnimationFrame(() => list.classList.remove('is-switching'));
    }, 160);
  });
</script>
